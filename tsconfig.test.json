{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "module": "commonjs",
    "verbatimModuleSyntax": false,
    "moduleResolution": "node",
    "allowImportingTsExtensions": false,
    "noEmit": false,
    "types": ["node", "jest", "@testing-library/jest-dom"]
  },
  "include": [
    "src/**/*.test.tsx",
    "src/**/*.test.ts",
    "src/**/__tests__/*",
    "src/setupTests.ts",
    "src/utils/test-utils.tsx",
    "src/**/*.d.ts"
  ]
}
